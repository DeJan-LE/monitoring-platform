# ================================================================
# .env – Umgebungsvariablen
# ================================================================

# --- Datenbank ---
POSTGRES_DB=monitoring
POSTGRES_USER=monitor
POSTGRES_PASSWORD=[Passwort hier]

# --- Flask ---
SECRET_KEY=supergeheim123

# --- IT-Zugangscode ---
# Wer diesen Code bei der Registrierung eingibt, wird als IT-User registriert
IT_CODE=it_for_users26

# --- Mail (Gmail) ---
# App-Passwort unter https://myaccount.google.com/apppasswords erstellen
MAIL_USER=[Mail adresse]
MAIL_PASS=[App-passwort von der Mail]
MAIL_FROM=Incident System [<mail adresse>]

# --- App URL (für Links in Mails) ---
# Auf VM-IP anpassen, z.B. http://192.168.1.50
APP_URL=https://not-promote-requirement-puts.trycloudflare.com

# --- Heartbeat ---
KUMA_HEARTBEAT_URL=http://uptime-kuma:3001/api/push/UpydTUpkrW?status=up&msg=OK&ping=
HEARTBEAT_INTERVAL=60
